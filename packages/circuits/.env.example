# =============================================================================
# zk_faucet — Circuit Testing Environment (packages/circuits/.env)
# =============================================================================
# Can target a different chain than server/frontend (e.g. Sepolia for testing).
# Copy to .env:  cp .env.example .env
# =============================================================================

# [REQUIRED] Chain ID for proof generation (e.g. Sepolia for testing).
ORIGIN_CHAINID=11155111

# [REQUIRED] Minimum ETH balance required (in wei).
MIN_BALANCE_WEI=1000000000000000

# [REQUIRED] RPC URL for the target chain.
ORIGIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# [REQUIRED] Private key of the account to prove balance for (0x-prefixed).
PRIVATE_KEY=0x...
